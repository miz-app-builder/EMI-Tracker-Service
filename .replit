modules = ["web", "bash", "nodejs-22", "python-3.11"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "EMI Tracker Frontend"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Artifact Router"

[[workflows.workflow]]
name = "EMI Tracker Frontend"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=5000 BASE_PATH=/ pnpm --filter @workspace/emi-tracker run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "Artifact Router"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "$REPLIT_ARTIFACT_ROUTER"
waitForPort = 8000

[workflows.workflow.metadata]
outputType = "console"

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 3000
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3003

[[ports]]
localPort = 8000
externalPort = 8000

[[ports]]
localPort = 19185
externalPort = 3000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
BASE_PATH = "/"
